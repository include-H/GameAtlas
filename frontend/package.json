{
  "name": "nas-game-library-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "npm run lint:eslint && npm run lint:policy",
    "lint:eslint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:policy": "node ./scripts/check-text-action-buttons.mjs",
    "lint:unused": "npm run lint:eslint -- --max-warnings=0 && npm run lint:policy",
    "knip": "knip"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "axios": "^1.7.9",
    "markdown-it": "^14.1.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^26.0.0",
    "knip": "^5.88.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^6.0.11",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
}
