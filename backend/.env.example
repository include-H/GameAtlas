APP_ENV=development
HOST=0.0.0.0
PORT=3000

# Core paths
DB_PATH=data/db.db
STATIC_DIR=../frontend/dist
ASSETS_DIR=data/gamelist
MIGRATIONS_DIR=migrations

# ROM library root
PRIMARY_ROM_ROOT=ROM

# SMB launch script settings
SMB_SHARE_ROOT=\\192.168.1.4\Game
SMB_USERNAME=
SMB_PASSWORD=
VHD_DIFF_ROOT=C:

# Admin auth
ADMIN_DISPLAY_NAME=Admin
ADMIN_PASSWORD=
SESSION_SECRET=change-me
AUTH_MAX_FAILS=5
AUTH_COOLDOWN=10m
AUTH_FAIL_WINDOW=30m
AUTH_STATE_TTL=24h
AUTH_TRACK_BY=ip_ua
WIKI_HISTORY_LIMIT=100

# Optional outbound proxy settings
PROXY=
# Leave these empty unless you need per-protocol overrides.
HTTP_PROXY=
HTTPS_PROXY=
STEAM_PROXY=

LOG_LEVEL=info
READ_HEADER_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
