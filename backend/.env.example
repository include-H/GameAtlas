APP_ENV=development
HOST=0.0.0.0
PORT=3000

# Core paths
DB_PATH=data/db.db
STATIC_DIR=../frontend/dist
ASSETS_DIR=data/gamelist
MIGRATIONS_DIR=migrations

# NAS library roots
ALLOWED_LIBRARY_ROOTS=ROM
PRIMARY_ROM_ROOT=ROM

# Optional outbound proxy settings
PROXY=
# Leave these empty unless you need per-protocol overrides.
HTTP_PROXY=
HTTPS_PROXY=
STEAM_PROXY=

LOG_LEVEL=info
READ_HEADER_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
